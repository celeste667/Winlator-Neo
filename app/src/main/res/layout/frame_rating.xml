<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="2dp"
        android:layout_marginTop="2dp"
        android:layout_marginLeft="10dp"
        android:gravity="center_vertical"
        android:background="#33000000">

        <!-- FPS Panel -->
        <LinearLayout
            android:id="@+id/LLFPSPanel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textStyle="bold"
                android:textSize="12dp"
                android:text="FPS:"
                android:textColor="#FF003F"
                android:shadowColor="#000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:layout_marginRight="5dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textStyle="bold"
                android:textSize="12dp"
                android:text="0"
                android:textColor="#F0F0F0"
                android:shadowColor="#000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:includeFontPadding="false"
                android:maxLines="1" />
        </LinearLayout>

        <!-- BAT Panel (logo abaixo do FPS, só no modo FULL) -->
        <LinearLayout
            android:id="@+id/LLBATPanel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textStyle="bold"
                android:textSize="12dp"
                android:text="BAT:"
                android:textColor="#FF003F"
                android:shadowColor="#000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:layout_marginRight="5dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textStyle="bold"
                android:textSize="12dp"
                android:text="--"
                android:textColor="#F0F0F0"
                android:shadowColor="#000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:includeFontPadding="false"
                android:maxLines="1" />
        </LinearLayout>

        <!-- GPU Panel -->
        <LinearLayout
            android:id="@+id/LLGPUPanel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textStyle="bold"
                android:textSize="12dp"
                android:text="GPU:"
                android:textColor="#FF003F"
                android:shadowColor="#000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:layout_marginRight="5dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textStyle="bold"
                android:textSize="12dp"
                android:text="0"
                android:textColor="#F0F0F0"
                android:shadowColor="#000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:includeFontPadding="false"
                android:maxLines="1" />
        </LinearLayout>

        <!-- RAM Panel -->
        <LinearLayout
            android:id="@+id/LLRAMPanel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textStyle="bold"
                android:textSize="12dp"
                android:text="RAM:"
                android:textColor="#FF003F"
                android:shadowColor="#000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:layout_marginRight="5dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textStyle="bold"
                android:textSize="12dp"
                android:text="0"
                android:textColor="#F0F0F0"
                android:shadowColor="#000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:includeFontPadding="false"
                android:maxLines="1" />
        </LinearLayout>

        <!-- CPU Panel -->
        <LinearLayout
            android:id="@+id/LLCPUPanel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textStyle="bold"
                android:textSize="12dp"
                android:text="CPU:"
                android:textColor="#FF003F"
                android:shadowColor="#000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:layout_marginRight="5dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textStyle="bold"
                android:textSize="12dp"
                android:text="0"
                android:textColor="#F0F0F0"
                android:shadowColor="#000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:includeFontPadding="false"
                android:maxLines="1" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
